API_PREFIX=/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info

# IA — desenvolvimento (API key)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# AI_BACKEND=api_key

# IA — produção (Vertex AI + Application Default Credentials)
# AI_BACKEND=vertex
# GOOGLE_CLOUD_PROJECT=seu-projeto-gcp
# VERTEX_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Pesquisa jurídica — fontes públicas
# Chave pública CNJ (wiki DataJud); substitua se o CNJ rotacionar
# DATAJUD_API_KEY=
# Texto de acórdãos STJ/STF/TJs (opcional — jurisprudencias.ai)
# JURISPRUDENCIAS_API_TOKEN=

# Persistência de workflows (opcional)
# WORKFLOW_STORE_PATH=data/workflow_store.json

# Gráficos analytics (PNG)
# ANALYTICS_CHARTS_DIR=data/analytics/charts

# Multi-tenant (API key por escritório)
# AUTH_REQUIRED=false
# TENANTS_JSON=[{"tenant_id":"escritorio-a","name":"Escritório A","api_key":"dev-key-a"}]
# TENANT_KEYS_PATH=config/tenants.json

# Auditoria de consultas IA (sem texto integral — apenas hash + metadados)
# AI_AUDIT_ENABLED=true
# AUDIT_LOG_DIR=data/audit
# Trilha durável: com LOG_FORMAT=json, cada evento é emitido pelo logger
# "ai_audit" para o Cloud Logging (persistente no Cloud Run, onde data/audit/
# é efêmero). Consultas em ops/cloud-logging-queries.md.

# Cache de pesquisa externa (DataJud / Senado)
# SEARCH_CACHE_ENABLED=true
# SEARCH_CACHE_TTL_SECONDS=900
# SEARCH_CACHE_PERSIST=false
# SEARCH_CACHE_DIR=data/search_cache

# Rate limiting (por tenant ou IP quando público)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=120
# RATE_LIMIT_WINDOW_SECONDS=60

# Redis (rate limit + cache distribuído em produção / multi-instância)
# REDIS_URL=redis://localhost:6379/0
# docker compose up -d redis

# Monitoramento (Sentry + Cloud Logging via stdout JSON)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=legal-ai-platform@2.0.0
# LOG_FORMAT=json

# Alertas Slack (falhas IA + complemento ao Sentry)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_ALERTS_ENABLED=true
