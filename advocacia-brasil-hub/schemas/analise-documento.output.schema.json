{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://legal-ai.local/schemas/analise-documento.output.json",
  "title": "AnaliseDocumentoOutput",
  "type": "object",
  "required": ["document_type", "summary", "entities", "metadata"],
  "properties": {
    "document_type": {
      "type": "string",
      "description": "ID de ontology/tipos-documento.yaml"
    },
    "legal_area": {
      "type": "string",
      "description": "ID de ontology/areas-direito.yaml"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "text", "confidence"],
        "properties": {
          "type": { "type": "string" },
          "text": { "type": "string" },
          "normalized_value": { "type": "string" },
          "confidence": { "type": "number" },
          "context": { "type": "string" }
        }
      }
    },
    "legal_concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "concept": { "type": "string" },
          "category": { "type": "string" },
          "related_articles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": { "type": "number" }
        }
      }
    },
    "summary": { "type": "string" },
    "key_points": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gaps": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Lacunas processuais ou formais detectadas"
    },
    "opportunities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" },
          "probability": { "type": "number" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "disclaimer": { "type": "string" },
        "processing_time_ms": { "type": "number" },
        "model": { "type": "string" }
      }
    }
  }
}
